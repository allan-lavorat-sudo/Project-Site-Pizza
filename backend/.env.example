# Backend Environment Variables (.NET)

# Database
ConnectionStrings__DefaultConnection=Server=localhost;Database=PizzaDeliveryDB;User Id=sa;Password=YourPassword123!;Encrypt=false;

# JWT Settings
JwtSettings__Secret=your-super-secret-key-change-in-production-min-32-chars
JwtSettings__Issuer=pizzadelivery.api
JwtSettings__Audience=pizzadelivery.clients
JwtSettings__ExpiryMinutes=60
JwtSettings__RefreshExpiryDays=7

# Ifood Settings
IfoodSettings__ApiBaseUrl=https://api.ifood.com.br
IfoodSettings__PartnerApiToken=your_ifood_api_token
IfoodSettings__MerchantId=your_merchant_id
IfoodSettings__ClientId=your_client_id
IfoodSettings__ClientSecret=your_client_secret
IfoodSettings__WebhookSecret=your_webhook_secret

# CORS
Cors__AllowedOrigins__0=http://localhost:3000
Cors__AllowedOrigins__1=http://localhost:3001

# Email (Optional)
Email__SmtpServer=smtp.gmail.com
Email__SmtpPort=587
Email__SmtpUsername=your_email@gmail.com
Email__SmtpPassword=your_app_password

# Logging
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft=Warning

# Environment
ASPNETCORE_ENVIRONMENT=Development
